## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.
##
## This .gitignore file is based on the VisualStudio.gitignore template from
## https://github.com/github/gitignore

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww]in32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
log/
logs/

# Visual Studio 2015/2017/2019/2022 cache/options directory
.vs/
# Uncomment if you want to ignore the project-level .vs directory
# .vs/

# Visual Studio 2017 Auto-generated files
Generated\ Files/

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# NUnit
*.VisualState.xml
TestResult.xml
nunit-*.xml

# Build log of MSBuild
*.log
*.tlog
*.lastbuildstate

# CoreCLR dumps
core.[0-9]*

# Visual Studio 2015/2017/2019/2022 Quick Replace results
.vs/

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Visual Studio 2015/2017/2019/2022 SQL Server files
*.ntvs_analysis.dat
*.com_analysis.dat

# Folder for analysis results
My\ Get\ Code\ Analysis\ Results/

# Replacement for NuGet.exe
*.nupkg
# NuGet symbol packages
*.snupkg
# The packages folder can be ignored because of Package Restore
**/[Pp]ackages/*
# except build/, which is used as an MSBuild target.
!**/[Pp]ackages/build/
# Uncomment if using NuGet repositories to store flags
#!**/[Pp]ackages/flags/
# MSBuild Auto-generated cache files
*.nuget.cache
# The "project.lock.json" file is generated by the "dotnet restore" command
# and should not be committed to git.
project.lock.json
project.assets.json

# Backup and restore files from Visual Studio
_Changelist*
_UpgradeReport*
*.backup
*.bak

# Others
sql/
*.sln.metaproj
*.sln.metaproj.tmp
*.dbmdl
*.dbproj.schemaview
*.jfm
*.pfx
*.publishsettings
*.suo
*.vshost.exe
*.vshost.exe.config
*.vshost.exe.manifest
*.xml
# EXCEPT
!Neathread/appsettings.json
!Neathread/appsettings.Development.json

# Visual Studio Code
.vscode/
.history/
.ionide/

# JetBrains
.idea/
*.sln.iml
*.sln.dotSettings.user

# Mac
.DS_Store

# End of .gitignore
